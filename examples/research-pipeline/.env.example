# Copy this file to .env and fill in your keys.

# Tavily — free tier at https://tavily.com (1000 searches/month)
TAVILY_API_KEY=

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Where the AgentMesh control plane is reachable from the agents.
# Default works for local dev with `make run` in the project root.
AGENTMESH_CONTROL_PLANE=localhost:9091
